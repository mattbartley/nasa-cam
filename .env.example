# Database connection (Neon - pulled from Vercel with `vercel env pull`)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: Secret for cron job authentication (generate a random string)
CRON_SECRET="your-random-secret-here"

# Base URL of the standalone perseverance-api (Cloudflare Worker) that serves the
# activity endpoint used by the DatePicker. Leave empty for same-origin; set to
# the deployed Worker URL in production, or http://localhost:8787 when running it
# locally via `wrangler dev`.
REACT_APP_API_BASE=""
