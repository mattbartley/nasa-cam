# Database connection (Neon - pulled from Vercel with `vercel env pull`)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: Secret for cron job authentication (generate a random string)
CRON_SECRET="your-random-secret-here"
