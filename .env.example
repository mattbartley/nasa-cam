# Database connection (Neon — pulled from Vercel with `vercel env pull`)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/database?sslmode=require"

# Optional. The manifest, photos, and activity endpoints are all served by this
# app's own /api functions, so leave this empty to use the same origin. Only set
# it to another host's base URL if you want the frontend to fetch the API from
# somewhere other than where this app is deployed. (Read via import.meta.env,
# with REACT_APP_ kept as the prefix in vite.config.mjs.)
REACT_APP_API_BASE=""
